# OASIS bruto e dados processados — nunca commitar (volume + dados sensíveis de pacientes)
# IMPORTANTE: usar barra inicial para ancorar à raiz; senão git ignora src/data/ no Windows (case-insensitive)
/data/
/Data/
*.nii

# Trabalho comparativo (CNN/) — manter o .ipynb mas ignorar as imagens do dataset interno (~1.5GB)
CNN/**/Alzheimer's dataset/
CNN/**/AugmentedAlzheimerDataset/
CNN/**/OriginalDataset/
!CNN/**/*.ipynb
*.nii.gz
*.npy
*.h5
*.hdf5

# Checkpoints e logs de treino — binários, não versionar
*.pt
*.pth
*.ckpt
experiments/**/checkpoints/
experiments/**/logs/
wandb/
mlruns/
# Atenção: NÃO usar regra genérica `runs/` — ela casa com qualquer pasta
# `runs/` em qualquer profundidade (Windows case-insensitive, ver F-0006).
# Em particular ignoraria experiments/runs/ que QUEREMOS versionar
# (config.yaml, history.json e final_test_metrics.json das runs reais).

# Runs de smoke test (sanity check, não evidência — não versionar)
/experiments/runs/*_smoke*/
/experiments/runs/*smoke*/

# Resultados pesados (manter só os finais, escolher manualmente o que commitar)
results/**/*.png
results/**/*.jpg
!results/**/final_*.png
!results/**/final_*.jpg

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/

# Ambientes virtuais
.venv/
venv/
env/

# IDE / SO
.vscode/
.idea/
.DS_Store
Thumbs.db

# Segredos
.env
.env.*
!.env.example

# Logs de instalação / setup
install.log
*.log

# Textos de PDF extraídos para auditoria (regeneráveis via src/data/extract_paper_texts.py)
_paper_texts/